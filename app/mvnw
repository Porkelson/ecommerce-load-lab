#!/bin/sh
# Maven Wrapper script
# Adapted from official Spring Initializr mvnw

set -e

# Locate the script's own directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_PROJECTBASEDIR="$SCRIPT_DIR"

# Download Maven if not already cached
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"
MVN_BIN="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MVN_BIN" ]; then
  mkdir -p "$MAVEN_HOME"
  DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.tar.gz"
  TMP_FILE="$MAVEN_HOME/mvn.tar.gz"
  echo "Downloading Maven 3.9.6..."
  curl -sL "$DOWNLOAD_URL" -o "$TMP_FILE"
  tar -xzf "$TMP_FILE" --strip-components=1 -C "$MAVEN_HOME"
  rm "$TMP_FILE"
fi

exec "$MVN_BIN" "$@"
